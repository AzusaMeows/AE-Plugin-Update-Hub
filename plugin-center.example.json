  "items": [
    {
      "kind": "native",
      "source": "Plug-ins/Deep Glow.aex",
      "target": "{commonPlugins}/Plugin Everything/Deep Glow",
      "name": "Deep Glow.aex"
    },
    {
      "kind": "cep",
      "source": "Panel",
      "target": "{cepExtensions}",
      "targetName": "DeepGlowPanel"
    }
  ],
  "postInstall": "Deep Glow 示例包已复制完成。部分原生插件需要授权文件或官方运行库，请按插件厂商要求完成激活。"
